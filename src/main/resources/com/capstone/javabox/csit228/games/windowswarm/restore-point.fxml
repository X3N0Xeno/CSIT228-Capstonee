<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER" spacing="15"
      style="-fx-background-color: #000000; -fx-border-color: #00FF41; -fx-border-width: 2px;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="SYSTEM RESTORE MENU"
           style="-fx-text-fill: #00FF41; -fx-font-family: 'Courier New'; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <HBox alignment="CENTER" spacing="10">
        <TextField fx:id="playerNameInput" promptText="ENTER ALIAS"
                   style="-fx-background-color: #000000; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-font-family: 'Courier New';"/>
        <Button fx:id="saveBtn" text="UPLOAD SCORE"
                style="-fx-background-color: #000000; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-font-family: 'Courier New'; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <HBox alignment="CENTER" spacing="20">
        <Button fx:id="rebootBtn" text="REBOOT"
                style="-fx-background-color: #000000; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-font-family: 'Courier New'; -fx-font-weight: bold; -fx-cursor: hand;"/>
        <Button fx:id="lobbyBtn" text="LOBBY"
                style="-fx-background-color: #000000; -fx-text-fill: #00FF41; -fx-border-color: #00FF41; -fx-font-family: 'Courier New'; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

</VBox>