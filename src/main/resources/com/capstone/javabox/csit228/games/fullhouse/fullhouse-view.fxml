<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #0b120d;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.capstone.javabox.csit228.games.fullhouse.FullHouseController">
    <children>

        <VBox fx:id="racePane" alignment="CENTER" maxWidth="1050" spacing="20" visible="false">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <Label text="THE ESTATE DERBY" style="-fx-text-fill: #d4af37; -fx-font-size: 36px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                </HBox>

                <StackPane alignment="CENTER_LEFT" style="-fx-border-color: #2b3d2f; -fx-border-width: 2;">
                    <children>
                        <VBox spacing="0">
                            <Pane prefHeight="80.0" prefWidth="1000.0" style="-fx-border-color: #2b3d2f; -fx-border-width: 0 0 2 0;">
                                <Label fx:id="lH1" text="House 1" textFill="#d4af37" layoutX="10.0" layoutY="5.0" style="-fx-font-family: 'Georgia'; -fx-font-size: 16px;"/>
                                <Label fx:id="qH1" text="Status" layoutX="120.0" layoutY="-5.0" style="-fx-text-fill: #ffffff; -fx-font-style: italic; -fx-font-size: 13px; -fx-background-color: #0b120dBB; -fx-padding: 3 8; -fx-background-radius: 8; -fx-border-color: #d4af37; -fx-border-radius: 8; -fx-border-width: 1;"/>
                                <ProgressBar fx:id="sH1" layoutX="10.0" layoutY="45.0" prefWidth="100.0" progress="1.0" style="-fx-accent: #d4af37;"/>
                                <Rectangle fx:id="nH1" width="45.0" height="40.0" fill="#4a5d4e" stroke="#d4af37" strokeWidth="2" layoutX="120.0" layoutY="20.0"/>
                            </Pane>
                            <Pane prefHeight="80.0" prefWidth="1000.0" style="-fx-border-color: #2b3d2f; -fx-border-width: 0 0 2 0;">
                                <Label fx:id="lH2" text="House 2" textFill="#d4af37" layoutX="10.0" layoutY="5.0" style="-fx-font-family: 'Georgia'; -fx-font-size: 16px;"/>
                                <Label fx:id="qH2" text="Status" layoutX="120.0" layoutY="-5.0" style="-fx-text-fill: #ffffff; -fx-font-style: italic; -fx-font-size: 13px; -fx-background-color: #0b120dBB; -fx-padding: 3 8; -fx-background-radius: 8; -fx-border-color: #d4af37; -fx-border-radius: 8; -fx-border-width: 1;"/>
                                <ProgressBar fx:id="sH2" layoutX="10.0" layoutY="45.0" prefWidth="100.0" progress="1.0" style="-fx-accent: #d4af37;"/>
                                <Rectangle fx:id="nH2" width="45.0" height="40.0" fill="#2d4239" stroke="#d4af37" strokeWidth="2" layoutX="120.0" layoutY="20.0"/>
                            </Pane>
                            <Pane prefHeight="80.0" prefWidth="1000.0" style="-fx-border-color: #2b3d2f; -fx-border-width: 0 0 2 0;">
                                <Label fx:id="lH3" text="House 3" textFill="#d4af37" layoutX="10.0" layoutY="5.0" style="-fx-font-family: 'Georgia'; -fx-font-size: 16px;"/>
                                <Label fx:id="qH3" text="Status" layoutX="120.0" layoutY="-5.0" style="-fx-text-fill: #ffffff; -fx-font-style: italic; -fx-font-size: 13px; -fx-background-color: #0b120dBB; -fx-padding: 3 8; -fx-background-radius: 8; -fx-border-color: #d4af37; -fx-border-radius: 8; -fx-border-width: 1;"/>
                                <ProgressBar fx:id="sH3" layoutX="10.0" layoutY="45.0" prefWidth="100.0" progress="1.0" style="-fx-accent: #d4af37;"/>
                                <Rectangle fx:id="nH3" width="45.0" height="40.0" fill="#52392c" stroke="#d4af37" strokeWidth="2" layoutX="120.0" layoutY="20.0"/>
                            </Pane>
                            <Pane prefHeight="80.0" prefWidth="1000.0" style="-fx-border-color: #2b3d2f; -fx-border-width: 0 0 2 0;">
                                <Label fx:id="lH4" text="House 4" textFill="#d4af37" layoutX="10.0" layoutY="5.0" style="-fx-font-family: 'Georgia'; -fx-font-size: 16px;"/>
                                <Label fx:id="qH4" text="Status" layoutX="120.0" layoutY="-5.0" style="-fx-text-fill: #ffffff; -fx-font-style: italic; -fx-font-size: 13px; -fx-background-color: #0b120dBB; -fx-padding: 3 8; -fx-background-radius: 8; -fx-border-color: #d4af37; -fx-border-radius: 8; -fx-border-width: 1;"/>
                                <ProgressBar fx:id="sH4" layoutX="10.0" layoutY="45.0" prefWidth="100.0" progress="1.0" style="-fx-accent: #d4af37;"/>
                                <Rectangle fx:id="nH4" width="45.0" height="40.0" fill="#635934" stroke="#d4af37" strokeWidth="2" layoutX="120.0" layoutY="20.0"/>
                            </Pane>
                            <Pane prefHeight="80.0" prefWidth="1000.0">
                                <Label fx:id="lH5" text="House 5" textFill="#d4af37" layoutX="10.0" layoutY="5.0" style="-fx-font-family: 'Georgia'; -fx-font-size: 16px;"/>
                                <Label fx:id="qH5" text="Status" layoutX="120.0" layoutY="-5.0" style="-fx-text-fill: #ffffff; -fx-font-style: italic; -fx-font-size: 13px; -fx-background-color: #0b120dBB; -fx-padding: 3 8; -fx-background-radius: 8; -fx-border-color: #d4af37; -fx-border-radius: 8; -fx-border-width: 1;"/>
                                <ProgressBar fx:id="sH5" layoutX="10.0" layoutY="45.0" prefWidth="100.0" progress="1.0" style="-fx-accent: #d4af37;"/>
                                <Rectangle fx:id="nH5" width="45.0" height="40.0" fill="#303b47" stroke="#d4af37" strokeWidth="2" layoutX="120.0" layoutY="20.0"/>
                            </Pane>
                        </VBox>

                        <Line startY="0" endY="400.0" stroke="#d4af37" strokeWidth="12.0" translateX="960" style="-fx-stroke-dash-array: 20 20;"/>
                    </children>
                </StackPane>

                <HBox spacing="20" alignment="CENTER_LEFT" prefHeight="80">
                    <Button fx:id="btnSpeed" text="SPEED: 1x" onAction="#handleSpeedToggle" style="-fx-background-color: #2b3d2f; -fx-text-fill: #e0e0e0; -fx-border-color: #e0e0e0; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                    <Button fx:id="btnNextRace" text="ONTO THE NEXT RACE!" visible="false" onAction="#handleNextRace" style="-fx-background-color: #d4af37; -fx-text-fill: #0b120d; -fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                    <Button fx:id="btnExit" text="RETURN TO PARLOR" visible="false" onAction="#onExitButtonClicked" style="-fx-background-color: #1a241c; -fx-text-fill: #d4af37; -fx-border-color: #d4af37; -fx-font-size: 16px; -fx-font-family: 'Georgia';"/>
                    <Label fx:id="lblStatus" text="AWAITING THE GUN..." style="-fx-text-fill: #728075; -fx-font-size: 18px; -fx-font-family: 'Georgia'; -fx-font-style: italic;"/>
                </HBox>
            </children>
        </VBox>

        <VBox fx:id="setupPane" alignment="CENTER" spacing="25.0" style="-fx-background-color: #0b120d; -fx-padding: 40;">
            <children>
                <Label text="THE BETTING PARLOR" style="-fx-text-fill: #d4af37; -fx-font-size: 48px; -fx-font-weight: bold; -fx-font-family: 'Georgia';"/>
                <Label text="Inspect the manors. Place your wagers." style="-fx-text-fill: #728075; -fx-font-size: 18px; -fx-font-family: 'Georgia'; -fx-font-style: italic;"/>

                <HBox fx:id="cardContainer" alignment="CENTER" spacing="20.0" />

                <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #1a241c; -fx-padding: 15; -fx-border-color: #2b3d2f; -fx-border-width: 2; -fx-max-width: 600;">
                    <children>
                        <TextField fx:id="txtPlayerName" prefWidth="250.0" promptText="Your Name, Sir/Madam" style="-fx-font-size: 16px; -fx-background-color: #0b120d; -fx-text-fill: #d4af37; -fx-border-color: #d4af37;"/>
                        <Button onAction="#handlePlaceBet" style="-fx-background-color: #d4af37; -fx-text-fill: #0b120d; -fx-font-weight: bold; -fx-font-size: 16px; -fx-font-family: 'Georgia';" text="PLACE WAGER"/>
                    </children>
                </HBox>

                <TextArea fx:id="txtBets" editable="false" prefHeight="120.0" prefWidth="600.0" maxWidth="600" style="-fx-font-size: 14px; -fx-control-inner-background: #0b120d; -fx-text-fill: #d4af37; -fx-border-color: #2b3d2f; -fx-font-family: 'Courier New';"/>

                <Button fx:id="btnStartRaceMenu" disable="true" onAction="#handleStartRace" style="-fx-background-color: #1b4d2e; -fx-border-color: #d4af37; -fx-border-width: 2; -fx-text-fill: #d4af37; -fx-font-weight: bold; -fx-font-size: 24px; -fx-padding: 10 40; -fx-font-family: 'Georgia';" text="FIRE THE STARTING GUN"/>
                <Label text="Two wagers minimum to start the derby." style="-fx-text-fill: #4a5d4e; -fx-font-family: 'Georgia';"/>
            </children>
        </VBox>

    </children>
</StackPane>