<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<HBox prefHeight="400.0" prefWidth="600.0" stylesheets="@../lobby-style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.capstone.javabox.csit228.games.JavaboxController">
   <children>
      <VBox HBox.hgrow="ALWAYS">
         <children>
            <Label text="JAVABOX">
               <font>
                  <Font name="Rockwell" size="40.0" />
               </font>
            </Label>
            <StackPane prefHeight="150.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
               <children>
                  <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: transparent; -fx-padding: 0;" vbarPolicy="NEVER">
                     <content>
                        <VBox fx:id="gameContainer" prefHeight="200.0" prefWidth="100.0" spacing="15.0">
                           <padding>
                              <Insets bottom="80.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                        </VBox>
                     </content>
                  </ScrollPane>
                   <Region maxHeight="100" mouseTransparent="true" style="-fx-background-color: linear-gradient(to bottom, transparent, #FFFFFF);" />
               </children>
            </StackPane>
         </children>
      </VBox>
      <StackPane prefHeight="150.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
   </children>
   <padding>
      <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
   </padding>
</HBox>
