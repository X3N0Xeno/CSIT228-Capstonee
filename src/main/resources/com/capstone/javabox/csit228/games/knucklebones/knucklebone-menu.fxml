                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>
                <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="player1" style="-fx-font-weight: bold;" text="PLAYER 1">
                                    <font><Font size="24.0" /></font>
                                </Label>
                                <TextField fx:id="p1Name" promptText="ENTER NAME" styleClass="modern-textfield">
                                    <VBox.margin><Insets left="60.0" right="60.0" /></VBox.margin>
                                </TextField>
                                <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                                    <children>
                                        <HBox alignment="CENTER" prefHeight="0.0" prefWidth="200.0" spacing="8.0">
                                            <children>
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: white;" styleClass="color-swatch">
                                                    <toggleGroup><ToggleGroup fx:id="p1Color" /></toggleGroup>
                                                </ToggleButton>
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #ff6e69;" styleClass="color-swatch" toggleGroup="$p1Color" />
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #7aff69;" styleClass="color-swatch" toggleGroup="$p1Color" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER" prefHeight="0.0" prefWidth="200.0" spacing="8.0">
                                            <children>
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #5eafff;" styleClass="color-swatch" toggleGroup="$p1Color" />
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #debbfc;" styleClass="color-swatch" toggleGroup="$p1Color" />
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #db66ff;" styleClass="color-swatch" toggleGroup="$p1Color" />
                                            </children>
                                        </HBox>
                                    </children>
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                </VBox>
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                        <Separator orientation="VERTICAL" prefHeight="200.0" />
                        <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="100.0" spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="player2" style="-fx-font-weight: bold;" text="PLAYER 2">
                                    <font><Font size="24.0" /></font>
                                </Label>
                                <TextField fx:id="p2Name" promptText="ENTER NAME" styleClass="modern-textfield">
                                    <VBox.margin><Insets left="60.0" right="60.0" /></VBox.margin>
                                </TextField>
                                <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" spacing="10.0">
                                    <children>
                                        <HBox alignment="CENTER" prefHeight="0.0" prefWidth="200.0" spacing="8.0">
                                            <children>
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: white;" styleClass="color-swatch">
                                                    <toggleGroup><ToggleGroup fx:id="p2Color" /></toggleGroup>
                                                </ToggleButton>
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #ff6e69;" styleClass="color-swatch" toggleGroup="$p2Color" />
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #7aff69;" styleClass="color-swatch" toggleGroup="$p2Color" />
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER" prefHeight="0.0" prefWidth="200.0" spacing="8.0">
                                            <children>
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #5eafff;" styleClass="color-swatch" toggleGroup="$p2Color" />
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #debbfc;" styleClass="color-swatch" toggleGroup="$p2Color" />
                                                <ToggleButton mnemonicParsing="false" onAction="#onToggleButtonClicked" style="-fx-background-color: #db66ff;" styleClass="color-swatch" toggleGroup="$p2Color" />
                                            </children>
                                        </HBox>
                                    </children>
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                </VBox>
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </children>
                </HBox>
                <HBox alignment="CENTER" prefHeight="0.0" prefWidth="200.0" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onStartRoundButtonClicked" prefHeight="40.0" prefWidth="200.0" styleClass="modern-button" text="START ROUND" />
                        <Button mnemonicParsing="false" onAction="#onBackToMenuClicked" prefHeight="40.0" prefWidth="200.0" styleClass="modern-button" text="BACK TO MENU" />
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</StackPane>