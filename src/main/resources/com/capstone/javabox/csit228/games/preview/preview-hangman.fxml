<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane style="-fx-background-color: #000000;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.capstone.javabox.csit228.games.previews.PreviewHangmanController">

    <Canvas fx:id="rouletteCanvas" height="600.0" width="600.0" />

    <VBox alignment="CENTER" spacing="-15">
        <Label text="HANGMAN" style="-fx-text-fill: #FFFFFF; -fx-font-size: 80px; -fx-font-family: 'Courier New'; -fx-font-weight: bold;">
            <effect>
                <DropShadow color="#e94560" radius="15" spread="0.6"/>
            </effect>
        </Label>
        <Label text="ROULETTE" style="-fx-text-fill: #e94560; -fx-font-size: 60px; -fx-font-family: 'Courier New'; -fx-font-weight: bold;">
            <effect>
                <DropShadow color="#000000" radius="15" spread="0.8"/>
            </effect>
        </Label>
    </VBox>
</StackPane>