<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.capstone.javabox.csit228.games.hangman.RouletteCanvas ?>

<StackPane fx:id="rootPane"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.capstone.javabox.csit228.games.hangman.HangmanController"
           style="-fx-background-color: #1a1a2e;">

    <VBox alignment="CENTER"
          spacing="20"
          style="-fx-padding: 30;">

        <Label text="💀 Hangman x Russian Roulette"
               style="-fx-font-family: Monospace; -fx-font-size: 22; -fx-text-fill: #e94560;"/>

        <Label fx:id="wordLabel"
               style="-fx-font-family: Monospace; -fx-font-size: 36; -fx-text-fill: #eaeaea;"/>

        <Label fx:id="bulletLabel"
               text="🔫 Wrong guesses: 0"
               style="-fx-font-family: Monospace; -fx-font-size: 16; -fx-text-fill: #f5a623;"/>

        <!-- Roulette cylinder -->
        <RouletteCanvas fx:id="rouletteCanvas"/>

        <Label fx:id="statusLabel"
               text="Guess a letter!"
               style="-fx-font-family: Monospace; -fx-font-size: 14; -fx-text-fill: #aaaaaa;"/>

        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="inputField"
                       maxWidth="60"
                       onAction="#handleGuess"
                       style="-fx-font-family: Monospace; -fx-font-size: 20;
                              -fx-background-color: #16213e; -fx-text-fill: white;
                              -fx-border-color: #e94560; -fx-border-radius: 4;
                              -fx-background-radius: 4;"/>

            <Button fx:id="guessButton"
                    text="Guess"
                    onAction="#handleGuess"
                    style="-fx-font-family: Monospace; -fx-font-size: 14;
                           -fx-background-color: #e94560; -fx-text-fill: white;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </HBox>

        <FlowPane fx:id="keyboardPane"
                  alignment="CENTER"
                  hgap="6"
                  vgap="6"
                  prefWrapLength="420"
                  style="-fx-padding: 10;"/>

        <HBox alignment="CENTER" spacing="10">
            <Button fx:id="restartButton"
                    text="New Game"
                    visible="false"
                    onAction="#handleRestart"
                    style="-fx-font-family: Monospace; -fx-font-size: 13;
                           -fx-background-color: #0f3460; -fx-text-fill: #eaeaea;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <Button text="Quit"
                    onAction="#handleQuit"
                    style="-fx-font-family: Monospace; -fx-font-size: 13;
                           -fx-background-color: #0f3460; -fx-text-fill: #eaeaea;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
        </HBox>

        <!-- Stats Panel -->
        <VBox fx:id="statsPane"
              visible="false"
              spacing="8"
              alignment="CENTER"
              style="-fx-background-color: #16213e; -fx-padding: 16;
                     -fx-border-color: #e94560; -fx-border-radius: 6;
                     -fx-background-radius: 6;">

            <Label text="📊 Statistics"
                   style="-fx-font-family: Monospace; -fx-font-size: 16; -fx-text-fill: #e94560;"/>

            <Label fx:id="statGames"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #eaeaea;"/>
            <Label fx:id="statWinRate"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #eaeaea;"/>
            <Label fx:id="statStreak"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #4caf50;"/>
            <Label fx:id="statBestStreak"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #f5a623;"/>
            <Label fx:id="statPulls"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #aaaaaa;"/>
            <Label fx:id="statDeaths"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #e94560;"/>

        </VBox>

    </VBox>

</StackPane>