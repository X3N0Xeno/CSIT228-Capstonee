<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.capstone.javabox.csit228.games.wordle.WordleController"
           style="-fx-background-color: #1a1a2e;">

    <VBox alignment="CENTER" spacing="16" style="-fx-padding: 30;">

        <Label text="🟩 Wordle — Hard Mastermind"
               style="-fx-font-family: Monospace; -fx-font-size: 22; -fx-text-fill: #e94560;"/>

        <Label text="🟩 correct position   🔄 misplaced count   reuse greens!"
               style="-fx-font-family: Monospace; -fx-font-size: 11; -fx-text-fill: #555588;"/>

        <GridPane fx:id="guessGrid" alignment="CENTER"/>

        <Label fx:id="statusLabel"
               text="Guess the 5-letter word!"
               style="-fx-font-family: Monospace; -fx-font-size: 14; -fx-text-fill: #aaaaaa;"/>

        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="inputField"
                       promptText="Type a word..."
                       maxWidth="180"
                       onAction="#handleSubmit"
                       style="-fx-font-family: Monospace; -fx-font-size: 18;
                              -fx-background-color: #16213e; -fx-text-fill: white;
                              -fx-border-color: #e94560; -fx-border-radius: 4;
                              -fx-background-radius: 4; -fx-prompt-text-fill: #555588;"/>

            <Button fx:id="submitButton"
                    text="Submit"
                    onAction="#handleSubmit"
                    style="-fx-font-family: Monospace; -fx-font-size: 14;
                           -fx-background-color: #e94560; -fx-text-fill: white;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="restartButton"
                        text="New Game"
                        visible="false"
                        onAction="#handleRestart"
                        style="-fx-font-family: Monospace; -fx-font-size: 13;
                           -fx-background-color: #0f3460; -fx-text-fill: #eaeaea;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
                <Button text="Quit"
                        onAction="#handleQuit"
                        style="-fx-font-family: Monospace; -fx-font-size: 13;
                           -fx-background-color: #0f3460; -fx-text-fill: #eaeaea;
                           -fx-border-radius: 4; -fx-background-radius: 4; -fx-cursor: hand;"/>
            </HBox>
        </HBox>

        <!-- Stats Panel -->
        <VBox fx:id="statsPane"
              visible="false"
              spacing="8"
              alignment="CENTER"
              style="-fx-background-color: #16213e; -fx-padding: 16;
                     -fx-border-color: #e94560; -fx-border-radius: 6;
                     -fx-background-radius: 6;">

            <Label text="📊 Statistics"
                   style="-fx-font-family: Monospace; -fx-font-size: 16; -fx-text-fill: #e94560;"/>

            <Label fx:id="statGames"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #eaeaea;"/>
            <Label fx:id="statWinRate"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #eaeaea;"/>
            <Label fx:id="statStreak"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #4caf50;"/>
            <Label fx:id="statBestStreak"
                   style="-fx-font-family: Monospace; -fx-font-size: 13; -fx-text-fill: #f5a623;"/>

            <Label text="Guess Distribution:"
                   style="-fx-font-family: Monospace; -fx-font-size: 12; -fx-text-fill: #aaaaaa;"/>

            <VBox fx:id="distributionChart" spacing="4" alignment="CENTER_LEFT"/>

        </VBox>



    </VBox>

</StackPane>